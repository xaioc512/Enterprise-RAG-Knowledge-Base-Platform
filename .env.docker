# ============================================
# 企业AI知识库平台 — Docker 环境变量
# 复制此文件为 .env 并填入真实值
# ============================================

# --- 应用 ---
APP_NAME=RAG知识库平台
APP_VERSION=0.1.0
DEBUG=false

# --- 数据库（Docker Compose 服务名） ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=rag_user
MYSQL_PASSWORD=change-me-in-production
MYSQL_DATABASE=rag_platform

# --- MySQL Root 密码（docker-compose 初始化用） ---
MYSQL_ROOT_PASSWORD=root-change-me

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- DeepSeek API ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_EMBED_MODEL=deepseek-embedding

# --- JWT ---
JWT_SECRET=change-me-use-a-strong-random-string-at-least-32-chars-long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- 管理员注册密钥 ---
ADMIN_REGISTRATION_KEY=admin-key-change-me

# --- Chroma ---
CHROMA_PERSIST_DIR=/app/chroma_data

# --- 文件上传 ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS_STR=.pdf,.docx,.md,.txt
